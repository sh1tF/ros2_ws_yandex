<?xml version="1.0"?>
<robot name="simple_robot">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <joint name="base_to_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.15 0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_left_link">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.15 -0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_right_link">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_left_back_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_back_link"/>
    <origin xyz="-0.15 0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_left_back_link">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_right_back_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_back_link"/>
    <origin xyz="-0.15 -0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_right_back_link">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_led_front_left" type="fixed">
    <parent link="base_link"/>
    <child link="led_front_left_link"/>
    <origin xyz="0.2 0.12 0.05" rpy="0 0 0"/>
  </joint>
  <link name="led_front_left_link">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="base_to_led_front_right" type="fixed">
    <parent link="base_link"/>
    <child link="led_front_right_link"/>
    <origin xyz="0.2 -0.12 0.05" rpy="0 0 0"/>
  </joint>
  <link name="led_front_right_link">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="base_to_led_back_left" type="fixed">
    <parent link="base_link"/>
    <child link="led_back_left_link"/>
    <origin xyz="-0.2 0.12 0.05" rpy="0 0 0"/>
  </joint>
  <link name="led_back_left_link">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="base_to_led_back_right" type="fixed">
    <parent link="base_link"/>
    <child link="led_back_right_link"/>
    <origin xyz="-0.2 -0.12 0.05" rpy="0 0 0"/>
  </joint>
  <link name="led_back_right_link">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.2 0 0.075" rpy="0 0 0"/>
  </joint>
  <link name="camera_link">
    <visual>
      <geometry><box size="0.05 0.1 0.05"/></geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  <link name="lidar_link">
    <visual>
      <geometry><cylinder length="0.05" radius="0.05"/></geometry>
      <material name="green"/>
    </visual>
  </link>

</robot>

